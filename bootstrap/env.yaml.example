---
# This is a template for deploying the IDP into a new environment.
# Copy this file, rename it (e.g., staging.yaml), and update the values below.
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: idp-example-env
  namespace: argocd
  annotations:
    argocd.argoproj.io/sync-wave: "0"
spec:
  project: platform
  source:
    # TODO: Change this to your actual repository URL
    repoURL: 'https://github.com/YOUR_ORG/idp-starter-kit.git'
    targetRevision: HEAD
    # Point to your environment-specific overlay directory
    path: environments/example-env
    kustomize:
      enableHelm: true
  destination:
    server: https://kubernetes.default.svc
    namespace: argocd
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
      - ServerSideApply=true
