{
  "realm": "idp",
  "id": "idp",
  "enabled": true,
  "registrationAllowed": false,
  "groups": [
    { "name": "platform-admins", "path": "/platform-admins" },
    { "name": "developers", "path": "/developers" }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@idp.local",
      "firstName": "Platform",
      "lastName": "Admin",
      "credentials": [{ "type": "password", "value": "admin", "temporary": false }],
      "groups": ["platform-admins"]
    },
    {
      "username": "dev",
      "enabled": true,
      "email": "dev@idp.local",
      "firstName": "Software",
      "lastName": "Developer",
      "credentials": [{ "type": "password", "value": "dev", "temporary": false }],
      "groups": ["developers"]
    }
  ],
  "clients": [
    {
      "clientId": "argocd",
      "enabled": true,
      "publicClient": true,
      "redirectUris": ["http://localhost:8080/auth/callback", "https://argocd.local/auth/callback"],
      "webOrigins": ["+"],
      "protocol": "openid-connect"
    },
    {
      "clientId": "grafana",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "dummy-secret",
      "redirectUris": ["http://grafana.local/login/generic_oauth"],
      "protocol": "openid-connect"
    },
    {
      "clientId": "vault",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dummy-secret",
      "redirectUris": ["http://vault.local/ui/vault/auth/oidc/oidc/callback"],
      "protocol": "openid-connect"
    }
  ],
  "clientScopes": [
    {
      "name": "groups",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.page": "true"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "roles",
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "defaultDefaultClientScopes": ["groups", "profile", "email", "roles", "web-origins"]
}
